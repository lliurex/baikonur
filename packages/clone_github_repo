#!/bin/bash
pool_repository="unstable"
if [ "$1" = "-r" ]; then
	shift
	pool_repository=$1
	shift
fi
repo=$1
shift
branch=$1
shift
cd /srv/autobuildinbox
git clone https://$(cat /run/secrets/githubuser)@github.com/$repo
cd */
git checkout $branch
cd ..
upstream=$1
if [ "$upstream" != "" ]; then
	cd */
	git checkout $upstream
	git checkout $branch
	cd ..
	echo "Upstream: $upstream" >> ${repo##*\/}.temp
fi
echo "Repository: $pool_repository" >> ${repo##*\/}.temp
dpkg-parsechangelog -l */debian/changelog >> ${repo##*\/}.temp
cat ${repo##*\/}.temp > ${repo##*\/}.baikonur
rm ${repo##*\/}.temp
